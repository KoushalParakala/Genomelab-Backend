# ─── GenomeLab Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# For local SQLite (default, no setup needed):
# Leave SUPABASE_DB_URL unset.

# For Supabase PostgreSQL (recommended for production):
# SUPABASE_DB_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# USE_SUPABASE=true   # set to true when using Supabase

# ── Supabase ──────────────────────────────────────────────────────────────────
# SUPABASE_URL=https://[project-ref].supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Set to * in dev. In production, use your actual frontend URL(s).
# ALLOWED_ORIGINS=https://helix-lab.onrender.com,https://yourdomain.com

# ── AI Models ─────────────────────────────────────────────────────────────────
# ESM model variant — smaller = faster startup, less RAM
# ESM_MODEL_NAME=esm2_t6_8M_UR50D
